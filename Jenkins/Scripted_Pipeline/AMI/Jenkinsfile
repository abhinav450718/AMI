node {
    def REPO_URL      = 'https://github.com/your-org/your-repo.git'
    def BRANCH        = 'main'
    def SLACK_CHANNEL = '#ci-operation-notifications'
    def AWS_REGION    = 'us-east-1'
    def AMI_NAME      = 'my-app-ami'

    try {

        stage('Clean Workspace') {
            cleanWs()
        }

        stage('Checkout Code') {
            git branch: BRANCH, url: REPO_URL
        }

        stage('Validate Packer Template') {
            withCredentials([
                string(credentialsId: 'AWS_ACCESS_KEY_ID',     variable: 'AWS_ACCESS_KEY_ID'),
                string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
            ]) {
                sh '''
                    export AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
                    export AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY
                    packer init packer/ami.pkr.hcl
                    packer validate packer/ami.pkr.hcl
                '''
            }
        }

        stage('Build AMI') {
            withCredentials([
                string(credentialsId: 'AWS_ACCESS_KEY_ID',     variable: 'AWS_ACCESS_KEY_ID'),
                string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
            ]) {
                sh """
                    export AWS_ACCESS_KEY_ID=\$AWS_ACCESS_KEY_ID
                    export AWS_SECRET_ACCESS_KEY=\$AWS_SECRET_ACCESS_KEY

                    packer build \
                        -var 'aws_region=${AWS_REGION}' \
                        -var 'ami_name=${AMI_NAME}' \
                        packer/ami.pkr.hcl | tee packer-output.log

                    grep 'AMI:' packer-output.log | awk '{print \$NF}' > ami-id.txt
                    echo "Built AMI ID: \$(cat ami-id.txt)"
                """
            }
            env.AMI_ID = sh(script: 'cat ami-id.txt', returnStdout: true).trim()
        }

        stage('Archive Reports') {
            archiveArtifacts artifacts: 'packer-output.log, ami-id.txt', allowEmptyArchive: true
        }

    } catch (Exception err) {
        currentBuild.result = 'FAILURE'
        throw err
    } finally {
        stage('Post Actions') {
            if (currentBuild.result == 'FAILURE') {
                slackSend(
                    channel: SLACK_CHANNEL,
                    color: 'danger',
                    message: "*FAILED* - AMI Build\n" +
                             "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n" +
                             "*Job Name:*       " + env.JOB_NAME + "\n" +
                             "*Build Number:*   #" + env.BUILD_NUMBER + "\n" +
                             "*Branch:*         " + BRANCH + "\n" +
                             "*Status:*         AMI Build Failed\n" +
                             "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n" +
                             "<" + env.BUILD_URL + "|View Build>"
                )
            } else {
                slackSend(
                    channel: SLACK_CHANNEL,
                    color: 'good',
                    message: "*SUCCESS* - AMI Build\n" +
                             "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n" +
                             "*Job Name:*       " + env.JOB_NAME + "\n" +
                             "*Build Number:*   #" + env.BUILD_NUMBER + "\n" +
                             "*Branch:*         " + BRANCH + "\n" +
                             "*AMI ID:*         " + env.AMI_ID + "\n" +
                             "*Status:*         AMI Created Successfully\n" +
                             "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n" +
                             "<" + env.BUILD_URL + "|View Build>   |   " +
                             "<" + env.BUILD_URL + "artifact/packer-output.log|Packer Log>"
                )
            }
            cleanWs()
        }
    }
}
