node {
    def REPO_URL   = 'https://github.com/abhinav450718/AMI.git'
    def BRANCH     = 'main'
    def AWS_REGION = 'us-east-1'
    def AMI_NAME   = 'my-app-ami'

    try {

        stage('Clean Workspace') {
            cleanWs()
        }

        stage('Checkout Code') {
            git branch: BRANCH, url: REPO_URL
        }

        stage('Validate Packer Template') {
            withCredentials([[
                $class: 'AmazonWebServicesCredentialsBinding',
                credentialsId: 'aws-creds'
            ]]) {
                sh '''
                    packer init packer/ami.pkr.hcl
                    packer validate packer/ami.pkr.hcl
                '''
            }
        }

        stage('Build AMI') {
            withCredentials([[
                $class: 'AmazonWebServicesCredentialsBinding',
                credentialsId: 'aws-creds'
            ]]) {
                sh """
                    packer build \\
                        -var 'aws_region=${AWS_REGION}' \\
                        -var 'ami_name=${AMI_NAME}' \\
                        packer/ami.pkr.hcl | tee packer-output.log

                    grep -i 'ami-' packer-output.log | tail -1 | awk '{print \$NF}' > ami-id.txt
                """
            }

            env.AMI_ID = sh(script: 'cat ami-id.txt', returnStdout: true).trim()
        }

        stage('Archive Reports') {
            archiveArtifacts artifacts: 'packer-output.log, ami-id.txt', allowEmptyArchive: true
        }

        currentBuild.result = 'SUCCESS'

    } catch (Exception err) {
        currentBuild.result = 'FAILURE'
        throw err

    } finally {
        stage('Post Actions') {
            echo "Build Status: ${currentBuild.result}"

            if (currentBuild.result == 'SUCCESS') {
                echo "✅ AMI Created Successfully: ${env.AMI_ID}"
            } else {
                echo "❌ AMI Build Failed"
            }

            cleanWs()
        }
    }
}
